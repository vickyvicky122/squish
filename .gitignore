# ============================================================
#  Gradle
# ============================================================
.gradle/
build/

# Keep the Gradle wrapper so others can bootstrap without a local install
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# ============================================================
#  Kotlin / JS
# ============================================================
# kotlin-js-store/yarn.lock IS intentionally committed —
# it locks JS dependency versions for reproducible builds.
# Ignore nothing inside kotlin-js-store.

